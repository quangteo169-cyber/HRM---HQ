# Chuỗi kết nối PostgreSQL (Neon / Vercel Postgres / Supabase)
# Ví dụ Neon: postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/hrm?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/hrm"

# Khóa bí mật cho NextAuth — tạo bằng lệnh: openssl rand -base64 32
NEXTAUTH_SECRET="thay-bang-chuoi-ngau-nhien-bi-mat"

# URL của ứng dụng (khi deploy Vercel: https://ten-du-an.vercel.app)
NEXTAUTH_URL="http://localhost:3000"
